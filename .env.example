# Copy this file to ".env" and fill in your keys.

# ---- Magic Shuffle (AI DJ) ----
# OpenAI powers context interpretation + the DJ voice. The app still runs fully
# WITHOUT this key (deterministic rules engine + template DJ lines take over).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

PORT=3000

# ---- Spotify grounding + optional in-app playback ----
# Client credentials let the AI DJ verify real Spotify tracks and album art.
# The redirect URI is used only when connecting a user for Web Playback SDK playback.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# ---- Weather (live) ----
# Open-Meteo is used for live weather. It is FREE and KEYLESS — nothing to set here.
# Location is auto-detected from the server IP. Optionally override with a city:
DEFAULT_LOCATION=

# ---- Biometrics ----
# V1 only ships the research-based mock generator. google_health / zepp are stubbed
# OFF for now (selecting them throws). Leave as "mock".
BIOMETRIC_PROVIDER=mock

# ---- Google Calendar (live, read-only; optional) ----
# Without these, the calendar gracefully falls back to a mock line and the app
# still works. To enable real events: create an OAuth client (type "Web
# application") in Google Cloud, enable the Calendar API, add the redirect URI
# below under "Authorized redirect URIs", and add your account as a test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/google/callback

# Optional: comma-separated origins for a separate frontend dev server.
# Loopback origins such as http://localhost:5173 are allowed by default.
CORS_ORIGINS=
