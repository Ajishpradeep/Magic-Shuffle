# Copy this file to ".env" and fill in your keys.

# ---- Magic Shuffle (AI DJ) ----
# OpenAI powers context interpretation + the DJ voice. The app still runs fully
# WITHOUT this key (deterministic rules engine + template DJ lines take over).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

PORT=3000

# ---- Spotify grounding + optional in-app playback ----
# Client credentials let the AI DJ verify real Spotify tracks and album art.
# The redirect URI is used only when connecting a user for Web Playback SDK playback.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# Optional: comma-separated origins for a separate frontend dev server.
# Loopback origins such as http://localhost:5173 are allowed by default.
CORS_ORIGINS=
